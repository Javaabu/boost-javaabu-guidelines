{
    "name": "javaabu/boost-javaabu-guidelines",
    "description": "Javaabu's Laravel & PHP coding guidelines for Laravel Boost",
    "homepage": "https://github.com/Javaabu/boost-javaabu-guidelines",
    "license": "MIT",
    "keywords": [
        "javaabu",
        "laravel",
        "boost_javaabu_guidelines"
    ],
    "authors": [
        {
            "name": "Arushad Ahmed",
            "email": "arushad@javaabu.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0 || ^13.0"
    },
    "autoload": {
        "psr-4": {
            "Javaabu\\BoostJavaabuGuidelines\\": "src/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0-dev"
        },
        "laravel": {
            "providers": [
                "Javaabu\\BoostJavaabuGuidelines\\BoostJavaabuGuidelinesServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
